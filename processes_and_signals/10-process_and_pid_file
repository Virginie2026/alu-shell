#!/usr/bin/env bash
# This script creates a PID file, handles multiple signals, and cleans up on exit

# Write current process ID to the required file
echo "$$" > /var/run/myscript.pid

# Function to handle SIGTERM
handle_term() {
    echo "I hate the kill command"
    rm -f /var/run/myscript.pid
    exit 0
}

# Function to handle SIGQUIT
handle_quit() {
    rm -f /var/run/myscript.pid
    exit 0
}

# Trap assignments
trap 'echo "Y U no love me?!"' SIGINT
trap 'handle_term' SIGTERM
trap 'handle_quit' SIGQUIT

# Infinite loop
while true
do
    echo "To infinity and beyond"
    sleep 2
done
